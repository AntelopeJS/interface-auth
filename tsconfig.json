{
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "types": ["node", "mocha"],
    "esModuleInterop": true,
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@antelopejs/interface-auth": ["src/index.ts"]
    },
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src"]
}
